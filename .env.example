NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://hit:hit@localhost:5432/hit_incidents?schema=public"
DATABASE_URL_TEST="postgresql://hit:hit@localhost:5432/hit_incidents?schema=e2e_test"
JWT_SECRET="change-me-in-local-development"
JWT_EXPIRES_IN="1h"
LOG_LEVEL="debug"
# LOG_FORMAT accepts "pretty" for local terminal logs or "json" for containers.
LOG_FORMAT="pretty"
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="admin"

# k6 benchmark defaults. Keep K6_BASE_URL commented when running k6 via Docker Compose,
# because the k6 container reaches the API through http://api:3000/api/v1.
# K6_BASE_URL="http://localhost:3000/api/v1"
K6_EMAIL="admin@hit.local"
K6_PASSWORD="Admin123!"
K6_ASSIGNEE_ID="356b57c6-9b8a-4576-8df6-cbd9799d8295"
K6_INCIDENT_ID="10000000-0000-4000-8000-000000000001"
K6_THINK_TIME_SECONDS="1"
K6_REQUEST_TIMEOUT="30s"
